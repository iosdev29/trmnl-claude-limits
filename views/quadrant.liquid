<script src="https://trmnl.com/js/highcharts/12.3.0/pattern-fill.js"></script>
<script type="text/javascript">
  (function () {
    var GAUGE = {
      START_ANGLE:         -150,
      END_ANGLE:            150,
      ARC_INNER_RADIUS:    "82%",
      ARC_BORDER_RADIUS:   "50%",
      TICK_PIXEL_INTERVAL:  40,
      DITHER_FILL_URL:     "https://trmnl.com/images/grayscale/gray-2.png",
      DITHER_TRACK_URL:    "https://trmnl.com/images/grayscale/gray-5.png",
      DITHER_TILE_SIZE:     10,
      LABEL_Y_OFFSET:       42,
      LABEL_FONT_SIZE:     "1.9em",
      LABEL_FONT_WEIGHT:   "600"
    };

    var score = {{ session_percent }};

    Highcharts.chart("gauge_session", {
      chart: { type: "gauge", animation: false, backgroundColor: "transparent", spacing: [0, 0, 0, 0] },
      title: { text: null },
      pane: {
        startAngle: GAUGE.START_ANGLE,
        endAngle:   GAUGE.END_ANGLE,
        background: { backgroundColor: "transparent", borderWidth: 0 }
      },
      plotOptions: {
        gauge: {
          animation: false,
          pivot: { backgroundColor: "transparent" },
          dial: { backgroundColor: "transparent", baseWidth: 0 }
        }
      },
      yAxis: {
        min: 0, max: 100,
        minorTickInterval: 0, tickColor: "#ffffff", tickLength: 0,
        tickPixelInterval: GAUGE.TICK_PIXEL_INTERVAL, tickWidth: 0, lineWidth: 0,
        title: { text: null },
        labels: { enabled: false },
        plotBands: [{
          from: 0.01, to: Math.max(score, 0.5),
          color: { pattern: { image: GAUGE.DITHER_FILL_URL, width: GAUGE.DITHER_TILE_SIZE, height: GAUGE.DITHER_TILE_SIZE } },
          innerRadius: GAUGE.ARC_INNER_RADIUS, borderRadius: GAUGE.ARC_BORDER_RADIUS
        }, {
          from: score + 0.5, to: 100,
          color: { pattern: { image: GAUGE.DITHER_TRACK_URL, width: GAUGE.DITHER_TILE_SIZE, height: GAUGE.DITHER_TILE_SIZE } },
          innerRadius: GAUGE.ARC_INNER_RADIUS, borderRadius: GAUGE.ARC_BORDER_RADIUS
        }]
      },
      series: [{
        name: "%",
        data: [score],
        dataLabels: {
          borderWidth: 0,
          y: GAUGE.LABEL_Y_OFFSET,
          format: "{y}%",
          style: {
            fontSize:   GAUGE.LABEL_FONT_SIZE,
            fontWeight: GAUGE.LABEL_FONT_WEIGHT,
            fontFamily: "inherit"
          }
        }
      }],
      credits: { enabled: false }
    });
  })();
</script>
