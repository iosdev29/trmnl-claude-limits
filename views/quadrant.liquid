<style>
  /* =====================================================================
     SIZING CONSTANTS — tune the quadrant (400x240) layout here.
     ===================================================================== */
  :root {
    --pr: var(--pixel-ratio, 1);

    /* Semicircle gauge fills the whole content area */
    --gauge-height:    calc(180px * var(--pr));

    /* Pixel-art mascot overlaid on the gauge — 768x512 viewBox */
    --mascot-width:    calc(72px  * var(--pr));
    --mascot-height:   calc(48px  * var(--pr));
    --mascot-top-inset: 32%;
  }

  /* Gauge + mascot overlay */
  .gauge-wrap { position: relative; height: var(--gauge-height); }
  .gauge-mascot {
    position: absolute;
    top: var(--mascot-top-inset); left: 0; right: 0;
    display: flex; justify-content: center;
    pointer-events: none;
    z-index: 2;
  }
  .gauge-mascot svg { width: var(--mascot-width); height: var(--mascot-height); }
</style>

{%- assign plan = plan_tier | default: trmnl.plugin_settings.custom_fields_values.claude_plan | default: "Max" -%}

{%- comment -%}
  Mascot mood mirrors the current session utilization.
    happy    : session < 40%
    neutral  : 40% <= session < 70%
    nervous  : 70% <= session < 90%
    critical : session >= 90%  OR  data is stale
{%- endcomment -%}
{%- assign _s = session_percent | default: 0 | plus: 0 -%}
{%- if is_stale or _s >= 90 -%}{%- assign mood = "critical" -%}
{%- elsif _s >= 70 -%}{%- assign mood = "nervous" -%}
{%- elsif _s >= 40 -%}{%- assign mood = "neutral" -%}
{%- else -%}{%- assign mood = "happy" -%}
{%- endif -%}

<div class="layout layout--col gap--space-between">

  <div class="flex flex--col flex--center-x flex--center-y stretch-y">

    <div class="gauge-wrap w--full">
      <div id="gauge_session" class="w--full h--full"></div>
      <div class="gauge-mascot" data-mood="{{ mood }}">
{%- case mood -%}
