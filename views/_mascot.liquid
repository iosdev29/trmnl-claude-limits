{%- comment -%}
  Claude mascot — pixel-perfect ASCII sticker for TRMNL e-ink.

  Grid: 30 columns × 14 rows. Each character cell = one source pixel.
  CSS must set `line-height: 1` (equal to font-size) so the full-block
  glyph U+2588 doesn't overlap the row below and dissolve the eye holes.

  Shape (sticker-accurate):
    row  0        ear tabs at cols 5-6 and 23-24
    row  1        top of body (rounded, 24 wide)
    row  2        top wide (26 wide)
    row  3        canonical body (26 wide); left/right arm reaches UP fills cols 0-1 or 28-29
    rows 4-5      ARMS + EYES — extend to full width (30 wide), with eye holes
                  carved in.  Arms stick out 2 cols beyond body silhouette on
                  each side — this is the sticker's arm bump.
    rows 6-11     body (26 wide inset)
    rows 12-13    two legs at cols 5-8 and 21-24 (4 wide each)

  Animation model (zero on-device cost):
    Mood       trigger                                  eye style
    happy      worst bucket < 40%                       4-wide, wide open
    neutral    40% ≤ worst < 70%                        3-wide standard
    worried    70% ≤ worst < 90%                        1-pixel dots
    panicked   worst ≥ 90% or is_stale                  'x' + arms raised (row 3 fills)

    Idle 0     canonical
    Idle 1     left arm reaches up (row 3 cols 0-1 fill)
    Idle 2     blink — eye rows 4-5 fill solid (suppressed on panicked)
    Idle 3     right arm reaches up (row 3 cols 28-29 fill)

  This file is a REFERENCE. Each view inlines the same logic.
{%- endcomment -%}

{%- assign worst = session_percent -%}
{%- if weekly_all_percent    > worst %}{% assign worst = weekly_all_percent    %}{% endif -%}
{%- if weekly_sonnet_percent > worst %}{% assign worst = weekly_sonnet_percent %}{% endif -%}
{%- if weekly_opus_percent   > worst %}{% assign worst = weekly_opus_percent   %}{% endif -%}
{%- if is_stale or worst >= 90 %}{% assign mood = "panicked" -%}
{%- elsif worst >= 70 %}{% assign mood = "worried" -%}
{%- elsif worst >= 40 %}{% assign mood = "neutral" -%}
{%- else %}{% assign mood = "happy" -%}{% endif -%}
{%- assign idle = frame_index | default: 0 | modulo: 4 -%}
{%- if mood == "panicked" and idle == 2 %}{% assign idle = 0 %}{% endif -%}

{%- if mood == "panicked" -%}
  {%- assign r3 = "██████████████████████████████" -%}
{%- elsif idle == 1 -%}
  {%- assign r3 = "████████████████████████████  " -%}
{%- elsif idle == 3 -%}
  {%- assign r3 = "  ████████████████████████████" -%}
{%- else -%}
  {%- assign r3 = "  ██████████████████████████  " -%}
{%- endif -%}

{%- if idle == 2 and mood != "panicked" -%}
  {%- assign r4 = "██████████████████████████████" -%}
  {%- assign r5 = "██████████████████████████████" -%}
{%- elsif mood == "happy" -%}
  {%- assign r4 = "███████    ████████    ███████" -%}
  {%- assign r5 = "███████    ████████    ███████" -%}
{%- elsif mood == "neutral" -%}
  {%- assign r4 = "████████   ████████   ████████" -%}
  {%- assign r5 = "████████   ████████   ████████" -%}
{%- elsif mood == "worried" -%}
  {%- assign r4 = "█████████ ██████████ █████████" -%}
  {%- assign r5 = "█████████ ██████████ █████████" -%}
{%- else -%}{%- comment -%}panicked{%- endcomment -%}
  {%- assign r4 = "█████████x██████████x█████████" -%}
  {%- assign r5 = "██████████████████████████████" -%}
{%- endif -%}

<pre class="mascot" data-mood="{{ mood }}" data-idle="{{ idle }}">     ██                ██
   ████████████████████████
  ██████████████████████████
{{ r3 }}
{{ r4 }}
{{ r5 }}
  ██████████████████████████
  ██████████████████████████
  ██████████████████████████
  ██████████████████████████
  ██████████████████████████
  ██████████████████████████
     ████            ████
     ████            ████     </pre>
